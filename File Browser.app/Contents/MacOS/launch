#!/bin/bash
export PATH="/usr/local/bin:/opt/homebrew/bin:$PATH"

PROJECT_DIR="/Users/jaysrinivasan/code/finder-replacement"
cd "$PROJECT_DIR"

# Kill any existing file-browser server
lsof -i :3000 -t 2>/dev/null | xargs kill 2>/dev/null

# Start server in background, detached from this process
nohup node server.js "$HOME" > /tmp/file-browser.log 2>&1 &

# Wait for server to be ready
for i in $(seq 1 20); do
  if curl -s http://localhost:3000/api/info > /dev/null 2>&1; then
    open http://localhost:3000
    exit 0
  fi
  sleep 0.25
done

# If we get here, server didn't start — open log
open /tmp/file-browser.log
exit 1
